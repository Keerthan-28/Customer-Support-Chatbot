# Server Configuration
PORT=5000
NODE_ENV=development

# OpenAI API Key (required for real LLM responses; mock used if absent)
OPENAI_API_KEY=your_openai_api_key_here
# MongoDB URI (optional - falls back to JSON file storage if not provided)
MONGODB_URI=mongodb://localhost:27017/chatbot

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
